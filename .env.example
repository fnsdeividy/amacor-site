# URL da API em produção (em desenvolvimento, o proxy do Vite redireciona /ws_* para api.amacor.cloud)
VITE_API_URL=https://api.amacor.cloud/webservice

# Token de autenticação da API do VPS (header x-internal-token)
VITE_API_TOKEN=

# URL do backend administrativo (Render). Em dev, deixe vazio para usar o proxy do Vite.
VITE_BACKEND_URL=https://amacor-site.onrender.com/api
