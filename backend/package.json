{
  "name": "amacor-backend",
  "version": "1.0.0",
  "description": "Backend API para plataforma Amacor - Autenticação administrativa e gestão de solicitações",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && node dist/scripts/migrate.js",
    "start": "node dist/src/index.js",
    "migrate": "ts-node-dev --transpile-only scripts/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "fast-check": "^3.23.2",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "vitest": "^2.1.8"
  }
}