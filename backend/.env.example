# ===========================================
# Configuração do Banco de Dados PostgreSQL
# ===========================================
# Formato: postgresql://usuario:senha@host:porta/nome_banco
# Exemplo com SSL: postgresql://usuario:senha@host:5432/amacor?sslmode=require
DATABASE_URL=postgresql://usuario:senha@localhost:5432/amacor

# ===========================================
# Configuração JWT (Autenticação Admin)
# ===========================================
# Segredo usado para assinar tokens JWT (HS256). Use um valor forte e único em produção.
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao
# Tempo de expiração do token JWT (formato: 8h, 1d, etc)
JWT_EXPIRATION=8h

# ===========================================
# Configuração CRM (Integração com webservice externo)
# ===========================================
# URL base do webservice do CRM (MH Vida)
CRM_BASE_URL=https://crm.exemplo.com.br/api

# ===========================================
# Configuração do Servidor
# ===========================================
# Porta onde o backend vai rodar
PORT=3001
# Ambiente de execução (development, production, test)
NODE_ENV=development
